@* ── Page d'accueil ───────────────────────────────────────────
   Redirige automatiquement vers /login si non connecté        *@
@page "/"
@implements IDisposable
@inject AuthService AuthService
@inject NavigationManager Nav

<div class="gb-screen-wrapper">
    <div class="gb-header"><span class="gb-pixel-title">★ BIENVENUE ★</span></div>
    <div class="gb-home">
        <img src="images/pokeball.svg" alt="Pokeball" class="pokeball-home" />
        <h2 class="gb-home-title">POKÉEXAM</h2>
        <p>
            <span class="typewriter-text">@displayedText</span>
            <br />
            FAIT AVEC BLAZOR
        </p>
        <button class="gb-btn gb-btn-primary" @onclick='() => Nav.NavigateTo("/pokedex")'>▶ JOUER</button>
    </div>
</div>

@code {
    private const string FullText = "MON POKÉDEX"; // The full text to be displayed with the typewriter effect
    private string displayedText = ""; // The text currently displayed
    private CancellationTokenSource cts = new CancellationTokenSource(); // Cancellation token source for the typewriter effect

    /// <summary>
    /// Checks if the user is authenticated when the component is initialized.
    /// If not, it redirects to the login page. Otherwise, it starts the typewriter effect.
    /// </summary>
    protected override async Task OnInitializedAsync()
    {
        if (!await AuthService.IsAuthenticated())
        {
            Nav.NavigateTo("/login");
        }
        else
        {
            await StartTypewriterEffect(cts.Token);
        }
    }

    /// <summary>
    /// Starts the typewriter effect to display the full text character by character.
    /// </summary>
    /// <param name="token">The cancellation token to stop the effect.</param>
    private async Task StartTypewriterEffect(CancellationToken token)
    {
        foreach (char c in FullText)
        {
            if (token.IsCancellationRequested) break;
            displayedText += c;
            StateHasChanged();
            await Task.Delay(150, token); // Adjust delay for typing speed
        }
    }

    /// <summary>
    /// Disposes the cancellation token source to prevent memory leaks.
    /// </summary>
    public void Dispose()
    {
        cts.Cancel();
        cts.Dispose();
    }
}
